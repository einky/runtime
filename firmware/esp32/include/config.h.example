// Copy to include/config.h and fill in for your environment. config.h is
// gitignored so secrets never get committed.
#pragma once

// --- WiFi (laptop hotspot) ---
#define EINKY_WIFI_SSID     "your-hotspot-ssid"
#define EINKY_WIFI_PASSWORD "your-hotspot-password"

// --- WSL endpoints ---
// On Windows, you typically need to port-forward the WSL2 ports to the host:
//   netsh interface portproxy add v4tov4 listenport=5333 connectaddress=<wsl-ip> connectport=5333
//   netsh interface portproxy add v4tov4 listenport=5334 connectaddress=<wsl-ip> connectport=5334
// Then point this at the laptop's hotspot IP (Windows default: 192.168.137.1).
// Or use `wsl --networking-mode=mirrored` and target the laptop IP directly.
#define EINKY_SERVER_HOST   "192.168.137.1"
#define EINKY_FRAME_PORT    5333
#define EINKY_INPUT_PORT    5334

// --- E-paper SPI pins (Waveshare 7.5" V2 reference wiring) ---
#define EPD_CS_PIN     5
#define EPD_DC_PIN    17
#define EPD_RST_PIN   16
#define EPD_BUSY_PIN   4
#define EPD_PWR_PIN   13
// SCK=18, MOSI=23 are the ESP32 default VSPI pins; no #define needed.

// --- Buttons (active-low, INPUT_PULLUP) ---
#define BTN_UP_PIN     32
#define BTN_DOWN_PIN   33
#define BTN_LEFT_PIN   25
#define BTN_RIGHT_PIN  26
#define BTN_A_PIN      27
#define BTN_B_PIN      14
#define BTN_START_PIN  12
